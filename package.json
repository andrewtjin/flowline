{
  "name": "flowline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Flowline — a fast, lightweight, clean-room debate-text editor on ProseMirror.",
  "license": "SEE LICENSE IN LICENSE",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "vite src/renderer --port 5173 --strictPort",
    "dev:electron": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:schema-hash": "tsx scripts/check-schema-hash.ts",
    "schema-hash:write": "tsx scripts/write-schema-hash.ts",
    "check": "npm run typecheck && npm run lint && npm run check:schema-hash && npm run test"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.8",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.41.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "electron": "^42.4.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "prosemirror-schema-basic": "^1.2.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
